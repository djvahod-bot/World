/* style.css */
@import url('https://fonts.googleapis.com/css2?family=Bungee+Shade&family=Press+Start+2P&display=swap');

:root {
    --primary-color: #00f0ff;
    --secondary-color: #ff007f;
    --background-color: #1a1a1a;
    --text-color: #ffffff;
    --button-color: #4CAF50;
    --button-hover-color: #45a049;
    --game-over-color: #ff0000;
    --start-screen-bg: #2a2a2a;
}

body {
    font-family: 'Press Start 2P', cursive;
    background-color: var(--background-color);
    color: var(--text-color);
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
    overflow: hidden;
    position: relative;
}

.game-container {
    text-align: center;
    background-color: rgba(0, 0, 0, 0.7);
    padding: 30px;
    border-radius: 10px;
    box-shadow: 0 0 20px rgba(0, 255, 255, 0.3);
    width: 90%;
    max-width: 800px;
    position: relative;
    z-index: 2;
}

h1 {
    font-family: 'Bungee Shade', cursive;
    color: var(--primary-color);
    font-size: 2.5em;
    margin-bottom: 20px;
    letter-spacing: 2px;
    text-shadow: 0 0 10px var(--primary-color), 0 0 20px var(--primary-color);
}

.stats {
    display: flex;
    justify-content: space-around;
    margin-bottom: 30px;
    font-size: 1.1em;
}

.stat-item {
    background-color: rgba(255, 255, 255, 0.1);
    padding: 10px 15px;
    border-radius: 5px;
    border: 1px solid var(--primary-color);
}

.stat-item span {
    color: var(--primary-color);
    font-weight: bold;
    font-size: 1.2em;
}

.game-area {
    width: 100%;
    height: 400px;
    border: 3px solid var(--secondary-color);
    background-color: rgba(255, 255, 255, 0.05);
    position: relative;
    overflow: hidden;
    cursor: crosshair;
    border-radius: 5px;
}

.target {
    position: absolute;
    background-color: var(--secondary-color);
    border-radius: 50%;
    cursor: pointer;
    transition: transform 0.1s ease-out, background-color 0.1s ease-out;
    box-shadow: 0 0 15px var(--secondary-color);
    border: 2px solid var(--text-color);
}

.target:hover {
    background-color: #ff66cc; /* Lighter pink on hover */
    transform: scale(1.1);
}

.start-screen, .game-over-screen {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background-color: var(--start-screen-bg);
    z-index: 3;
    border-radius: 8px;
}

.start-screen h2, .game-over-screen h2 {
    font-family: 'Bungee Shade', cursive;
    font-size: 2em;
    color: var(--primary-color);
    margin-bottom: 20px;
}

.start-screen p, .game-over-screen p {
    font-size: 1em;
    margin-bottom: 30px;
    max-width: 80%;
}

.start-screen button, .game-over-screen button {
    font-family: 'Press Start 2P', cursive;
    padding: 15px 30px;
    font-size: 1.2em;
    background-color: var(--button-color);
    color: var(--text-color);
    border: none;
    border-radius: 5px;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
}

