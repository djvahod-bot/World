body {
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #2c3e50; /* Dark blue-grey */
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    color: white;
    overflow: hidden;
}

.game-container {
    text-align: center;
    width: 90%;
    max-width: 600px;
    background-color: rgba(0, 0, 0, 0.3); /* کمی شفافیت برای کانتینر */
    padding: 20px;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

h1 {
    color: #1abc9c; /* Turquoise */
    margin-bottom: 20px;
    font-size: 2.8rem;
    text-shadow: 0 2px 5px rgba(0,0,0,0.4);
}

.stats {
    display: flex;
    justify-content: space-around;
    margin-bottom: 30px;
    font-size: 1.6rem;
}

.stat-box {
    background: #34495e; /* Darker blue-grey */
    padding: 12px 25px;
    border-radius: 10px;
    box-shadow: inset 0 2px 5px rgba(0,0,0,0.4);
    min-width: 120px; /* عرض کمتر تا بهتر چیده شوند */
}

#game-area {
    position: relative;
    width: 100%;
    height: 400px;
    background-color: #ecf0f1; /* Light grey */
    border-radius: 15px;
    cursor: crosshair;
    overflow: hidden;
    box-shadow: inset 0 0 20px rgba(0,0,0,0.2);
    margin-bottom: 20px;
}

.target {
    position: absolute;
    width: 50px; /* اندازه اولیه هدف */
    height: 50px;
    background-color: #e74c3c; /* Red */
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 15px rgba(231, 76, 60, 0.8);
    transition: transform 0.08s ease-out, box-shadow 0.1s ease; /* انیمیشن نرم‌تر */
    cursor: pointer;
}

.target:active {
    transform: translate(-50%, -50%) scale(0.7); /* هدف کوچک‌تر می‌شود */
    box-shadow: 0 0 25px rgba(231, 76, 60, 1);
}

#start-screen, #game-over {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(44, 62, 80, 0.9); /* پس‌زمینه تیره برای صفحات */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-radius: 15px; /* مطابق با game-area */
}

#game-over h2 {
    color: #f39c12; /* Orange */
    font-size: 3rem;
    margin-bottom: 15px;
}

#game-over p {
    font-size: 1.8rem;
    margin-bottom: 30px;
}

#game-over p span {
    font-weight: bold;
    color: #f1c40f; /* Yellow */
}

button {
    padding: 15px 35px;
    font-size: 1.3rem;
    cursor: pointer;
    background-color: #27ae60; /* Green */
    color: white;
    border: none;
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    transition: background-color 0.3s ease, transform 0.2s ease;
}

button:hover {
    background-color: #2ecc71; /* Lighter green */
    transform: translateY(-2px);
}

button:active {
    background-color: #27ae60;
    transform: translateY(0);
}

.hidden {
    display: none;
}

