// --- تنظیمات اولیه بازی ---
let score = 0;
let timeLeft = 30;
let timerInterval;
let gameActive = false;
let targetSpeedMultiplier = 1; // ضریب سرعت هدف‌ها
let baseTargetSize = 50; // اندازه پایه هدف

// --- المان‌های DOM ---
const scoreElement = document.getElementById('score');
const timerElement = document.getElementById('timer');
const gameArea = document.getElementById('game-area');
const startScreen = document.getElementById('start-screen');
const gameOverScreen = document.getElementById('game-over');
const finalScoreElement = document.getElementById('final-score');
const startBtn = document.getElementById('start-btn');
const restartBtn = document.getElementById('restart-btn');

// --- المان‌های صوتی ---
const clickSound = document.getElementById('click-sound');
const gameOverSound = document.getElementById('game-over-sound');
const backgroundMusic = document.getElementById('background-music');

// --- تابع پخش صدا (با مدیریت خطا) ---
function playSound(audioElement) {
    if (!audioElement) return; // اگر المان صدا وجود نداشت، خارج شو
    audioElement.currentTime = 0; // بازگرداندن به ابتدای فایل صوتی
    audioElement.play().catch(error => {
        console.warn("Failed to play sound:", error);
        // در مرورگرهای جدید، پخش خودکار صدا ممکن است محدود شود.
        // اگر صدا پخش نشد، ممکن است لازم باشد کاربر اولین تعامل را انجام دهد.
    });
}

// --- تابع پخش موسیقی پس‌زمینه ---
function playBackgroundMusic() {
    if (backgroundMusic) {
        backgroundMusic.play().catch(error => {
             console.warn("Background music failed to play. User interaction might be needed.", error);
        });
    }
}

// --- شروع بازی ---
function startGame() {
    score = 0;
    timeLeft = 30;
    targetSpeedMultiplier = 1; // ریست کردن ضریب سرعت
    baseTargetSize = 50; // ریست کردن اندازه هدف
    
    gameActive = true;
    scoreElement.innerText = score;
    timerElement.innerText = timeLeft;
    
    startScreen.classList.add('hidden');
    gameOverScreen.classList.add('hidden');
    
    // پاک کردن هدف‌های قبلی
    const existingTargets = document.querySelectorAll('.target');
    existingTargets.forEach(t => t.remove());

    // شروع موسیقی پس‌زمینه
    playBackgroundMusic();
    
    // شروع تایمر
    timerInterval = setInterval(updateTimer, 1000);
    
    // ایجاد اولین هدف
    spawnTarget();
}

// --- ایجاد هدف ---
function spawnTarget() {
    if (!gameActive) return;

    const target = document.createElement('div');
    target.classList.add('target');

    // محاسبه اندازه هدف بر اساس امتیاز (هر 10 امتیاز، 2 پیکسل کوچکتر)
    const currentTargetSize = Math.max(20, baseTargetSize - Math.floor(score / 10) * 2); // حداقل اندازه 20 پیکسل
    target.style.width = `${currentTargetSize}px`;
    target.style.height = `${currentTargetSize}px`;
    
    // محاسبه موقعیت تصادفی در محدوده game-area
    // باید از ابعاد واقعی game-area استفاده کنیم
    const gameAreaWidth = gameArea.clientWidth;
    const gameAreaHeight = gameArea.clientHeight;
    
    // اطمینان از اینکه هدف کاملاً درون محدوده قرار می‌گیرد
    const maxX = gameAreaWidth - currentTargetSize;
    const maxY = gameAreaHeight - currentTargetSize;
    
    const randomX = Math.floor(Math.random() * maxX);
    const randomY = Math.floor(Math.random() * maxY);

    target.style.left = `${randomX}px`;
    target.style.top = `${randomY}px`;

    // رویداد کلیک روی هدف
    target.addEventListener('mousedown', (event) => {
        if (!gameActive) return;
        event.stopPropagation(); // جلوگیری از فعال شدن رویداد کلیک game-area

        playSound(clickSound); // پخش صدای کلیک
        
        score++;
        scoreElement.innerText = score;
        
        // حذف هدف کلیک شده
        target.remove();

        // افزایش ضریب سرعت هدف‌ها با افزایش امتیاز
        if (score % 10 === 0) { // هر 10 امتیاز، سرعت کمی بیشتر می‌شود
            targetSpeedMultiplier += 0.1; 
        }

        // ایجاد هدف جدید
        spawnTarget();
    });

    gameArea.appendChild(target);
}

// --- به‌روزرسانی تایمر ---
function updateTimer() {
    timeLeft--;
    timerElement.innerText = timeLeft;

    if (timeLeft <= 0) {
        endGame();
    }
}

// --- پایان بازی ---
function endGame() {
    gameActive = false;
    clearInterval(timerInterval);
    finalScoreElement.innerText = score;
    gameOverScreen.classList.remove('hidden');
    
    // حذف تمام هدف‌های موجود در صفحه
    const targets = document.querySelectorAll('.target');
    targets.forEach(t => t.remove());

    // پخش صدای Game Over و توقف موسیقی پس‌زمینه
    playSound(gameOverSound);
    if (backgroundMusic) {
        backgroundMusic.pause();
        backgroundMusic.currentTime = 0; // بازگرداندن به ابتدا برای پخش مجدد
    }
}

// --- گوش دادن به دکمه‌ها ---
startBtn.addEventListener('click', () => {
    startGame();
});
restartBtn.addEventListener('click', () => {
    startGame();
});

// --- شروع بازی اولیه با کلیک روی دکمه "Start Game" ---
// این تضمین می‌کند که صداها در مرورگرهای سخت‌گیر پخش شوند
startBtn.addEventListener('click', () => {
    startGame();
});

// مدیریت پخش صداها در صورت نیاز به تعامل کاربر
document.addEventListener('click', function initializeAudio() {
    // یک بار صدا را پخش کن تا مجوز پخش صدا فعال شود
    if (backgroundMusic) {
        backgroundMusic.play().catch(() => {
            console.log('Audio playback requires user interaction.');
        });
        // حذف event listener پس از اولین کلیک موفق
        document.removeEventListener('click', initializeAudio);
    }
}, { once: true }); // {once: true} یعنی این listener فقط یک بار اجرا می‌شود
